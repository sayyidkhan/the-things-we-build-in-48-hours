---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Things We Build in 48 Hours",
  description = "A memoir documenting the journey of a builder seeking purpose through one hundred hackathons.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
