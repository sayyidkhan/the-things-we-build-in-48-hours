---
import { getCollection } from "astro:content";
import PageShell from "../components/PageShell.astro";
import HackathonTimeline from "../components/HackathonTimeline.astro";

const hackathons = (await getCollection("hackathons")).sort(
  (a, b) => b.data.number - a.data.number,
);
---

<PageShell title="Hackathons | The Things We Build in 48 Hours">
  <section class="archive-hero container">
    <h1 class="serif">Hackathon Archive</h1>
    <p>
      A running record of the one hundred hackathon journey: what was built,
      lessons, outcomes, stacks, and the pressure that shaped them.
    </p>
  </section>
  <section class="section container">
    <HackathonTimeline items={hackathons} />
  </section>
</PageShell>

<style>
  .archive-hero {
    padding: 76px 0 26px;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.5rem, 9vw, 9rem);
    line-height: 0.9;
  }

  p {
    max-width: 700px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.75;
  }
</style>
